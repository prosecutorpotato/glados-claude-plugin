{
  "description": "GLaDOS TTS - Speak responses in GLaDOS voice (session-scoped)",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/speak.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/session_end.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
